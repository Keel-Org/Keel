(def factorial (block (let acc (int 1)) (let i (int 1)) (loop-till (bin > (id i) (id n)) (assign ++ (id i)) (block (let acc (bin * (id acc) (id i))))) (return (id acc))) | (param n :(type int)))
(def fib (block (if (bin < (id n) (int 2)) (block (return (id n)))) (return (bin + (call (id fib) (bin - (id n) (int 1))) (call (id fib) (bin - (id n) (int 2)))))) | (param n :(type int)))
(def main (block (expr (call (id println) (str factorial(5) =) (call (id factorial) (int 5)))) (expr (call (id println) (str fib(10) =) (call (id fib) (int 10)))) (let greeting (str Keel)) (expr (call (id println) (interp (str hello from ) (id greeting)))) (let nums (call (id range) (int 1) (int 6))) (let doubled (call (field map (id nums)) (lambda (bin * (id x) (int 2)) (param x)))) (expr (call (id println) (str doubled:) (id doubled))) (expr (call (id println) (str sum:) (call (field sum (id doubled))))) (expr (call (id println) (str broadcast [1,2,3] * 10 =) (bin * (array (int 1) (int 2) (int 3)) (int 10))))) | (param sys :(type System)))
