(def parse_port (block (let n (try (call (field to_int (id raw))))) (if (logical or (bin < (id n) (int 1)) (bin > (id n) (int 65535))) (block (return (call (id fail) (str port out of range))))) (return (id n))) | (param raw :(type string)))
(def main (block (let port (execute (block (expr (try (call (id parse_port) (str 99999))))) | (handler Fail (block (expr (call (id println) (str config error:) (id e) (str -> using default))) (expr (unary resume (int 8080)))) (id e)))) (expr (call (id println) (str listening on port) (id port))) (let result (execute (block (let bad (try (call (id parse_port) (str abc)))) (expr (interp (str got ) (id bad)))) | (handler Fail (block (expr (str fell back to safe value))) (id e)))) (expr (call (id println) (str result:) (id result)))) | (param sys :(type System)))
