def find_even(xs: array[int]); int?:
    loop through xs:
        if it % 2 == 0:
            return it
    return none

def main(sys: System); Io:
    a = find_even([1, 3, 5, 8, 9])
    check a:
        is some(v):
            println("first even:", v)
        is none:
            println("no even")
    b = find_even([1, 3, 5])
    println("fallback:", b ?? 0 - 1)
