(enum Tree (variant Leaf (fielddef value :(type int))) (variant Node (fielddef left :(type int)) (fielddef right :(type int))))
(def tally (block (check (id t) (arm Leaf (block (return (id v))) (id v)) (arm Node (block (return (bin + (id l) (id r)))) (id l) (id r)))) | (param t :(type Tree)))
(def main (block (loop-through (array (call (id Leaf) (int 5)) (call (id Node) (int 3) (int 4))) (block (expr (call (id println) (str total =) (call (id tally) (id it))))))) | (param sys :(type System)))
