# Algebraic effects: Fail propagation, condition/restart via resume

def parse_port(raw: string); int / {Fail}:
    n = raw.to_int()?
    if n < 1 or n > 65535:
        return fail("port out of range")
    return n

def main(sys: System); Io:
    # `execute` with a handler that recovers by resuming a default value
    port = execute:
        parse_port("99999")?
    handle Fail as e:
        println("config error:", e, "-> using default")
        resume 8080
    println("listening on port", port)

    # a handler that aborts instead of resuming
    result = execute:
        bad = parse_port("abc")?
        "got #bad"
    handle Fail as e:
        "fell back to safe value"
    println("result:", result)
