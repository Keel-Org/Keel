def main(sys: System); Io:
    println([3, 1, 4, 1, 5, 9, 2, 6].sort())
    println(["pear", "apple", "fig"].sort())
    println([5, 3, 8, 1].min(), [5, 3, 8, 1].max())
    println([10, 20, 30, 40].index_of(30), [10, 20].index_of(99))
    println([1, 2, 3, 4, 5].reduce(0, (a, b): a + b))
    println("Hello, World".replace("o", "0").replace("l", "L"))
    println("file.keel".ends_with(".keel"), "file.keel".index_of("."))
    println("ab".repeat(4), "xyz".chars())
    mut acc = ""
    loop through "abc":
        acc = acc + it + str(i)
    println(acc)
